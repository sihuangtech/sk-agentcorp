# ============================================================
# SK AgentCorp — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ---- Database ----
# Default: SQLite (zero config). Set to postgres:// for production.
DATABASE_URL=sqlite:///./sk-agentcorp.db

# ---- LLM Providers ----
# (API keys and default models are now configured entirely via JSON in backend/llm_configs/)

# ---- Security ----
# Secret key for API authentication
API_SECRET_KEY=change-me-to-a-random-string
# Comma-separated list of allowed API keys for dashboard access
API_KEYS=sk-agentcorp-dev-key

# ---- Heartbeat ----
# How often (in seconds) the heartbeat wakes up the company
HEARTBEAT_INTERVAL_SECONDS=300

# ---- Budget ----
# Global budget cap in USD. System pauses when exceeded.
GLOBAL_BUDGET_CAP_USD=1000.00
# Per-task budget cap in USD
PER_TASK_BUDGET_CAP_USD=50.00

# ---- Anti-Stuck Engine ----
# Max retries before fallback to supervisor
MAX_TASK_RETRIES=3
# Task timeout in seconds
TASK_TIMEOUT_SECONDS=600

# ---- Frontend ----
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws

# ---- Logging ----
LOG_LEVEL=INFO
